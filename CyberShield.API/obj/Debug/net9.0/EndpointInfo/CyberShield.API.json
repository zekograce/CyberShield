    "/api/ProtectionPlans": {
      "get": {
        "tags": [
          "ProtectionPlans"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProtectionPlan"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProtectionPlan"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProtectionPlan"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "ProtectionPlans"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProtectionPlanDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProtectionPlanDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProtectionPlanDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProtectionPlan"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProtectionPlan"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProtectionPlan"
                }
              }
            }
          }
        }
      }
    },
